<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Required for hardened runtime -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Keychain access -->
    <key>keychain-access-groups</key>
    <array>
      <string>$(AppIdentifierPrefix)com.portfolio-tracker.desktop</string>
    </array>

    <!-- Touch ID via LocalAuthentication -->
    <key>com.apple.security.personal-information.biometric</key>
    <true/>

    <!-- Network (for price API calls) -->
    <key>com.apple.security.network.client</key>
    <true/>
  </dict>
</plist>
