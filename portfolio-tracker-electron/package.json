{
  "name": "portfolio-tracker-electron",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.mjs",
  "scripts": {
    "build:electron": "bun run build.electron.ts && cd ../portfolio-tracker && bun run build",
    "electron:dev": "bun run build.electron.ts && electron dist-electron/main.mjs",
    "electron:pack": "bun run build:electron && electron-builder",
    "migrate:encrypt": "node scripts/migrate-encrypt.js",
    "dev:api": "cd ../portfolio-api && bun run dev",
    "dev:ui": "cd ../portfolio-tracker && bun run dev"
  },
  "dependencies": {
    "better-sqlite3-multiple-ciphers": "^12.8.0",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0"
  },
  "trustedDependencies": [
    "better-sqlite3-multiple-ciphers"
  ]
}

